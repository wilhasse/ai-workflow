# Central API URL
API_URL=http://10.1.0.7:5002

# VM identifier (unique per VM)
VM_ID=my-vm-name

# Source data directories
CLAUDE_HOME=/home/cslog/.claude
CODEX_HOME=/home/cslog/.codex

# Sync interval (milliseconds, default 5 min)
SYNC_INTERVAL_MS=300000

# Local data directory for watermarks
DATA_DIR=/home/cslog/.agent-history-collector
